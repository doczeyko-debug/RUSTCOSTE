generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Explosive {
  id             String @id @default(uuid())
  name           String @unique // ej. "Rocket", "C4"
  sulfur         Int
  charcoal       Int
  metalFragments Int
  cloth          Int
  techTrash      Int
  damage         Int
  raidCosts      RaidCost[]
}

model RaidTarget {
  id             String @id @default(uuid())
  name           String @unique // ej. "Stone Wall"
  hp             Int
  category       String // "Wall", "Door", "Deployable", etc.
  raidCosts      RaidCost[]
}

model UserStats {
  userId         String @id
  queriesMade    Int    @default(0)
  totalSulfur    Int    @default(0)
}

model RaidCost {
  id          String     @id @default(uuid())
  targetId    String
  target      RaidTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  explosiveId String
  explosive   Explosive  @relation(fields: [explosiveId], references: [id], onDelete: Cascade)
  quantity    Int

  @@unique([targetId, explosiveId])
}

